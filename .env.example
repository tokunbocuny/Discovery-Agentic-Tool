# ──────────────────────────────────────────────────────────────────────────────
# Primo VE API Connector — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit your .env file to GitHub. It is already in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# --- REQUIRED ----------------------------------------------------------------

# Your API key from https://developers.exlibrisgroup.com
# Register → Build → My APIs → Manage Keys → Add API Key
# Permission needed: Primo / Search (read)
PRIMO_API_KEY=your_api_key_here

# --- INSTITUTION SETTINGS (confirm with CUNY OLS) ----------------------------
# CUNY Office of Library Services: https://ols-support.cuny.edu
# Email: support@cuny-ols.libanswers.com

# Primo VE View ID for your campus
# Confirmed BCC VID: 01CUNY_BX
# For the full CUNY network scope use: 01CUNY_NETWORK:CUNY_NETWORK
PRIMO_VID=01CUNY_BX

# Search scope (confirm in Primo Back Office or ask your Primo admin)
# Options typically include: MyInst_and_CI, MyInstitution, CI
PRIMO_SCOPE=MyInst_and_CI

# Search tab name (must match a configured tab in Primo VE Back Office)
PRIMO_TAB=Everything

# --- OPTIONAL ----------------------------------------------------------------

# Regional API gateway (NA = North America — correct for CUNY)
# Other regions: api-eu, api-ap, api-ca
PRIMO_BASE_URL=https://api-na.hosted.exlibrisgroup.com/primo/v1/search
